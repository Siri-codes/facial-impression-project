# Copy to .env and fill in. Never commit .env.

# --- Required: API access ---
OPENROUTER_API_KEY=your_key_here

# --- Optional: path overrides ---
# Only needed if the defaults don't work for your setup.

# Repo root. Auto-detected from src/config.py location.
# Set this only if running from a notebook or non-standard layout (e.g. Deepnote).
# PROJECT_ROOT=/work/facial_impression_project

# OMI face images. Not included in the repo (see README for download).
# Defaults to $PROJECT_ROOT/data/omi-main-dataset/images
# OMI_IMAGE_DIR=/work/20260629-213612/omi-main/images